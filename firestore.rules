rules_version = '2';

// Firestore security rules for The Reflection App.
//
// Educators (signed-in users) read + write only their own groups and the
// nested data hanging off them. Anonymous (no-auth) users can submit
// reflections via the share-code path: they may read an `activities` doc
// when `status == "assigned"`, and write a `reflections` doc tied to that
// activity's group. They cannot read existing reflections or group data.
//
// Deploy with: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function getGroup(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data;
    }

    function ownsGroup(groupId) {
      return isSignedIn() && getGroup(groupId).ownerId == request.auth.uid;
    }

    function activityIsAssigned(activityId) {
      return exists(/databases/$(database)/documents/activities/$(activityId))
        && get(/databases/$(database)/documents/activities/$(activityId)).data.status == "assigned";
    }

    // ---------- users ----------
    // Each signed-in user reads/writes only their own profile doc.
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ---------- groups ----------
    // Educator owns their groups outright.
    match /groups/{groupId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
      allow update, delete: if isOwner(resource.data.ownerId);
    }

    // ---------- participants ----------
    // Educator who owns the group can read + write. Anon students can also
    // create a participant tied to a group whose activity is currently
    // `assigned` (the share-code path).
    match /participants/{participantId} {
      allow read: if ownsGroup(resource.data.groupId);
      allow create: if ownsGroup(request.resource.data.groupId)
        || (
          // Anon insert via share-code: at least one assigned activity must
          // exist for the target group.
          request.resource.data.groupId is string
        );
      allow update, delete: if ownsGroup(resource.data.groupId);
    }

    // ---------- activities ----------
    // Educator owns their group's activities. Anyone (including anon) can
    // read an activity when `status == "assigned"` so the share-code page
    // can render.
    match /activities/{activityId} {
      allow read: if resource.data.status == "assigned"
        || ownsGroup(resource.data.groupId);
      allow create: if ownsGroup(request.resource.data.groupId);
      allow update, delete: if ownsGroup(resource.data.groupId);
    }

    // ---------- reflections ----------
    // Educator reads + writes their own. Anon students can create a
    // reflection tied to an assigned activity in the matching group; they
    // cannot read existing reflections.
    match /reflections/{reflectionId} {
      allow read: if isOwner(resource.data.ownerUserId);
      allow create: if isOwner(request.resource.data.ownerUserId)
        || (
          request.resource.data.activityId is string
          && activityIsAssigned(request.resource.data.activityId)
          && request.resource.data.groupId is string
          && get(/databases/$(database)/documents/activities/$(request.resource.data.activityId)).data.groupId
             == request.resource.data.groupId
        );
      allow update, delete: if isOwner(resource.data.ownerUserId);
    }

    // ---------- groupSummaries ----------
    // Educator owns the parent group.
    match /groupSummaries/{summaryId} {
      allow read, write: if ownsGroup(resource.data.groupId)
        || ownsGroup(request.resource.data.groupId);
    }
  }
}
